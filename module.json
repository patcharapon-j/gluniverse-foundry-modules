{
  "id": "gluniverse-suite",
  "title": "GLUniverse Suite",
  "description": "A unified suite of GLUniverse modules for Foundry VTT — clocks & trackers, initiative, weather, mission support, loot, cargo, critical animations, and more — all sharing one premium Etched Glass interface. Every module can be enabled or disabled individually from a single Feature Manager.",
  "version": "1.0.0",
  "compatibility": {
    "minimum": "13",
    "verified": "14",
    "maximum": ""
  },
  "authors": [{ "name": "GLUniverse" }],
  "esmodules": ["scripts/main.mjs"],
  "styles": [
    "styles/gl-tokens.css"
  ],
  "languages": [
    { "lang": "en", "name": "English", "path": "lang/en.json" }
  ],
  "relationships": {
    "recommended": [
      {
        "id": "tidy5e-sheet",
        "type": "module",
        "reason": "Required only for the Tidy 5e Inventory Slots feature.",
        "compatibility": { "minimum": "13.0.0" }
      }
    ]
  },
  "flags": {
    "gluniverse-suite": {
      "hotReload": {
        "extensions": ["css", "hbs", "html", "json"],
        "paths": ["styles", "templates", "lang", "scripts/features"]
      }
    }
  },
  "socket": true,
  "url": "https://github.com/patcharapon-j/gluniverse-foundry-modules",
  "manifest": "https://github.com/patcharapon-j/gluniverse-foundry-modules/releases/latest/download/module.json",
  "download": "https://github.com/patcharapon-j/gluniverse-foundry-modules/releases/latest/download/module.zip"
}
